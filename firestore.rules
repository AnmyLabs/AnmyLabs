rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function hasInterestRegisterFields() {
      return request.resource.data.keys().hasAll([
          'name',
          'email',
          'createdAt',
          'invited',
          'tester'
        ]) &&
        request.resource.data.keys().hasOnly([
          'name',
          'email',
          'createdAt',
          'invited',
          'tester'
        ]);
    }

    function isValidInterestRegisterCreate(emailId) {
      return hasInterestRegisterFields() &&
        request.resource.data.name is string &&
        request.resource.data.name.size() >= 2 &&
        request.resource.data.name.size() <= 120 &&
        request.resource.data.email is string &&
        request.resource.data.email == emailId &&
        request.resource.data.email.size() >= 6 &&
        request.resource.data.email.size() <= 254 &&
        request.resource.data.email.matches(
          '^[a-z0-9.!#$%&*+=?^_`{|}~-]+@[a-z0-9-]+(\\.[a-z0-9-]+)+$'
        ) &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.invited == false &&
        request.resource.data.tester == false;
    }

    match /interest_register/{emailId} {
      allow create: if isValidInterestRegisterCreate(emailId);
      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
